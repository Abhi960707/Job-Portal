# ==========================================
# Industry-Standard MERN Stack .gitignore
# ==========================================

# ─── Dependencies ─────────────────────────
node_modules/
jspm_packages/
.npm/
.pnpm-store/

# ─── Environment & Secrets ─────────────────
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.json
credentials.json
auth.json
firebase-admin.json
serviceAccountKey.json
config/development.json
config/production.json
config/local.json

# ─── Build Outputs ─────────────────────────
dist/
build/
out/
dist-ssr/
.next/
.serverless/
.netlify/
.vercel/

# ─── Logs & Diagnostics ────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.clinic/
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids/
*.pid
*.seed
*.pid.lock

# ─── Testing & Coverage ────────────────────
coverage/
.nyc_output/
.cypress/
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/

# ─── Caches ────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache
.tsbuildinfo
.npm/

# ─── Temp & Misc ───────────────────────────
temp/
tmp/
*.tmp
*.bak
*.swp
*.swo
*~
*.orig

# ─── OS Generated ──────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE & Editor ──────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
.fleet/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.workspace

# ─── Databases (Local) ─────────────────────
*.sqlite
*.sqlite3
*.db
*.db-journal
db.json

# ─── Misc ──────────────────────────────────
# Do not ignore lock files in version control, but you can ignore tarballs
*.tgz
*.gz